# ================================
# Spring Boot / Maven .gitignore
# ================================

# Maven build output
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# IDE - IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr

# IDE - Eclipse
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache

# IDE - VS Code
.vscode/

# OS
.DS_Store
Thumbs.db

# Environment & Credentials
.env
.env.local
*.pem
*.key
*.p12
*.jks
application-secret.yml
application-secret.properties

# Logs
*.log
logs/

# Maven wrapper (optional - uncomment if not committing wrapper)
# .mvn/

# Package files
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.rar

# Crash reports
hs_err_pid*
replay_pid*
